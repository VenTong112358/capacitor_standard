# Copy to .env.local and fill in from Supabase Project Settings → API.
#
# Supabase → Authentication → URL Configuration → Redirect URLs must include:
#   - http://localhost:3000   (Vite dev server; adjust port if you change vite.config)
#   - com.capacitor.standard://oauth-callback
#
# Enable Google and Apple providers under Authentication → Providers.
# Rename appId: also update src/utils/platform.ts NATIVE_OAUTH_REDIRECT, iOS URL Types,
# ViewController 3.swift callbackURLScheme, Android intent-filter, and Supabase redirects.

# Default project (replace if you fork): dashboard → /project/fsyodqwwbtwfkpaxdsst
VITE_SUPABASE_URL=https://fsyodqwwbtwfkpaxdsst.supabase.co
